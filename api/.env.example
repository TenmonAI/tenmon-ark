# TENMON-ARK API Server Environment Variables
# 本番環境では、このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# nano .env

# Node.js 環境
NODE_ENV=production

# サーバー設定
PORT=3000
HOST=127.0.0.1

# CORS 設定
# 本番環境では具体的なドメインを指定してください
# 例: CORS_ORIGIN=https://tenmon-ark.com
CORS_ORIGIN=*

# Mission Control vNext（read-only API + PWA /pwa/mc/vnext）。OFF=未マウント相当の挙動（保護APIは404）
# TENMON_MC_VNEXT=1

# MC vNext append-only ledgers（kokuzo.sqlite / mc_*_ledger）。TENMON_MC_VNEXT だけでは書かれない — こちらも 1 が必要
# 現状の実装では主に chat の NATURAL_GENERAL + llmChat(ledgerCtx) 経路で追記（御神託バイパス等は未接続のことがある）
# TENMON_MC_VNEXT_LEDGER=1

# MC vNext analyzer / acceptance / alert 集計（診断のみ・自動修正なし）。OFF でも ledger は残る
# TENMON_MC_VNEXT_ANALYZER=1

# CARD-MC-16: Claude / 外部 AI 用 read-only Bearer（最低 24 文字推奨 32+）。
# GET https://<host>/api/mc/vnext/claude-summary に Authorization: Bearer <token>（nginx の専用 location で Authorization を通す）
# TENMON_MC_CLAUDE_READ_TOKEN=

# Notion に MC 現状ミラーを書き込むページ UUID（ページを事前作成し、integration に共有）
# POST /api/mc/vnext/claude-notion-sync は founder JWT または MC Basic trust のみ（Claude token 不可）
# TENMON_NOTION_MC_CLAUDE_PAGE_ID=
