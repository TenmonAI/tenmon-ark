{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenmon-ark.local/automation/workspace_observer_schema_v1.json",
  "title": "AUTO_BUILD_WORKSPACE_OBSERVER_V1 snapshot",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "cardName",
    "generatedAt",
    "repoRoot",
    "git",
    "headSha",
    "queue",
    "humanGate",
    "generatedPatchRecipes",
    "generatedCursorTasks",
    "catalogDagValidation",
    "apiBuild",
    "latestReports",
    "singleFlight",
    "readyForApply",
    "readyViolations"
  ],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "cardName": { "type": "string", "const": "AUTO_BUILD_WORKSPACE_OBSERVER_V1" },
    "generatedAt": { "type": "string" },
    "repoRoot": { "type": "string" },
    "git": { "type": "object" },
    "headSha": { "type": "string" },
    "queue": { "type": "object" },
    "humanGate": { "type": "object" },
    "generatedPatchRecipes": { "type": "object" },
    "generatedCursorTasks": { "type": "object" },
    "catalogDagValidation": { "type": "object" },
    "apiBuild": { "type": "object" },
    "latestReports": { "type": "object" },
    "singleFlight": { "type": "object" },
    "readyForApply": { "type": "boolean" },
    "readyViolations": { "type": "array", "items": { "type": "string" } },
    "meta": { "type": "object" }
  }
}
