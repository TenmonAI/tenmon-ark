{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenmon.local/schemas/remote_build_job_normalized_v1.json",
  "title": "NormalizedRemoteBuildManifestV1",
  "description": "Mac 側 / 次工程へ渡す single source（TENMON_REMOTE_BUILD_JOB_NORMALIZER_V1）",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "card",
    "job_id",
    "card_name",
    "objective",
    "files",
    "edit_scope",
    "do_not_touch",
    "acceptance",
    "fail_next_card",
    "execution_mode",
    "safety_flags"
  ],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "card": { "type": "string", "const": "TENMON_REMOTE_BUILD_JOB_NORMALIZER_V1" },
    "job_id": { "type": "string", "minLength": 4 },
    "card_name": { "type": "string", "minLength": 1 },
    "objective": { "type": "string" },
    "files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "編集・参照の主ファイルパス（glob 可）"
    },
    "edit_scope": { "type": "array", "items": { "type": "string" } },
    "do_not_touch": { "type": "array", "items": { "type": "string" } },
    "acceptance": { "type": "array", "items": { "type": "string" } },
    "fail_next_card": { "type": "string" },
    "execution_mode": {
      "type": "string",
      "enum": ["dry_run", "apply", "manual"]
    },
    "safety_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rejected", "reject_reasons", "matched_danger_patterns", "defaults_applied"],
      "properties": {
        "rejected": { "type": "boolean" },
        "reject_reasons": { "type": "array", "items": { "type": "string" } },
        "matched_danger_patterns": { "type": "array", "items": { "type": "string" } },
        "defaults_applied": { "type": "array", "items": { "type": "string" } }
      }
    },
    "raw_card_body_md": { "type": "string", "description": "正規化元（省略可）" },
    "normalized_at": { "type": "string", "description": "ISO8601" }
  }
}
