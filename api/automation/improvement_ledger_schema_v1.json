{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenmon.local/schemas/improvement_ledger_entry_v1.json",
  "title": "TENMON_IMPROVEMENT_LEDGER_ENTRY_V1",
  "description": "TENMON_IMPROVEMENT_LEDGER_CURSOR_AUTO_V1 — JSONL 1 行 1 エントリ。記録項目は card_name / touched_files / blocker_types / acceptance_result / runtime_result / surface_result / route_result / density_result / recurrence_signals / next_card / summary_human_ja / summary_machine / outcome_class（+ seal 由来 longform_result）。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "entry_id",
    "recorded_at",
    "card_name",
    "outcome_class",
    "acceptance_result",
    "blocker_types",
    "runtime_result",
    "surface_result",
    "route_result",
    "longform_result",
    "density_result",
    "recurrence_signals",
    "next_card",
    "touched_files",
    "summary_human_ja",
    "summary_machine"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "entry_id": { "type": "string", "minLength": 8 },
    "recorded_at": { "type": "string", "description": "ISO8601 UTC Z" },
    "ledger_card": {
      "type": "string",
      "description": "ledger ランナー（TENMON_IMPROVEMENT_LEDGER_CURSOR_AUTO_V1）"
    },
    "card_name": { "type": "string", "minLength": 1 },
    "source_kind": {
      "type": "string",
      "enum": ["seal_dir", "manual_json", "cli_minimal"]
    },
    "seal_dir": { "type": "string", "description": "append-from-seal 時に設定" },
    "outcome_class": {
      "type": "string",
      "enum": ["success", "failure", "recurrence", "partial"]
    },
    "acceptance_result": {
      "type": "string",
      "enum": ["pass", "fail", "unknown"]
    },
    "blocker_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "runtime_result": { "type": "object" },
    "surface_result": { "type": "object" },
    "route_result": { "type": "object" },
    "longform_result": { "type": "object" },
    "density_result": { "type": "object" },
    "recurrence_signals": {
      "type": "object",
      "required": ["blocker_recurrence_counts", "notes"],
      "properties": {
        "blocker_recurrence_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "compared_tail_entries": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "next_card": {
      "type": "object",
      "required": ["primary_cursor", "primary_vps", "candidates"],
      "properties": {
        "primary_cursor": { "type": "string" },
        "primary_vps": { "type": "string" },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "cursor_card": { "type": "string" },
              "vps_card": { "type": "string" },
              "from_blocker": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "next_card_primary_cursor": {
      "type": "string",
      "description": "next_card.primary_cursor と同一の短縮参照（任意・追記時に付与）"
    },
    "touched_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary_human_ja": { "type": "string" },
    "summary_machine": {
      "type": "object",
      "properties": {
        "axes_ok": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "effective_axes": { "type": "array", "items": { "type": "string" } },
        "failed_axes": { "type": "array", "items": { "type": "string" } },
        "blocker_fingerprint": { "type": "string" },
        "seal_exit_code": { "type": "integer" }
      },
      "additionalProperties": true
    }
  }
}
