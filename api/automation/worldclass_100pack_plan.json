{
  "$schema_comment": "TENMON_WORLDCLASS_ASCENT_3STAGE_100PACK_V1 — 設計カードの機械可読マスター（100枚=10群×10）。実行は single_flight・群単位 acceptance。",
  "version": 1,
  "cardName": "TENMON_WORLDCLASS_ASCENT_3STAGE_100PACK_V1",
  "logPathPattern": "/var/log/tenmon/card_TENMON_WORLDCLASS_ASCENT_3STAGE_100PACK_V1/<TS>/run.log",
  "stages": [
    {
      "id": 1,
      "name": "CONVERSATION_FINAL_ASCENT",
      "objective": "会話OSを完成領域に固定。問い型ごとに天聞として崩れず一貫し長短自在。",
      "successCriteriaSummary": [
        "surface failure classes zero",
        "longform_shortfall zero",
        "route/surface miswire toward zero",
        "hasResponsePlan all required probes",
        "thread continuity alive",
        "routeReason vs surface alignment >= 0.95",
        "ask-overuse reduced",
        "3k/8k chapter structure stable"
      ]
    },
    {
      "id": 2,
      "name": "TOTAL_CIRCULATION_CLOSURE",
      "objective": "会話→memory→canon→KHS→growth→automation→次会話の閉ループ。",
      "successCriteriaSummary": [
        "thread_center_memory evidence",
        "carry projection / thread linkage effective",
        "thoughtGuide/persona/intention natural on surface",
        "growth candidate + ledger write evidence",
        "replay PASS",
        "execution_gate PASS",
        "manifest_missing_total=0",
        "workspace_dirty=false"
      ]
    },
    {
      "id": 3,
      "name": "WORLDCLASS_ASCENT_LOOP",
      "objective": "改善ループ自体の高性能化・継続改善帯。",
      "successCriteriaSummary": [
        "3 iterations overall score improvement",
        "all families strong+",
        "supreme_integration_score >= 95",
        "seal_allowed",
        "MAINLINE_COMPLETED_READ_ONLY_SEAL_V1 connected",
        "post-seal worldclass reveal PASS"
      ]
    }
  ],
  "executionPolicy": {
    "runMode": "single_flight",
    "oneCardOneVerification": true,
    "groupBoundaryAcceptance": true,
    "passGroupContinueOnly": true,
    "failGeneratesMinimalNextCard": true,
    "nightRunMaxConsecutiveCards": 8,
    "nightRunSummaryEveryNCards": 8,
    "stopOn": ["build_fail", "replay_fail", "manifest_regression", "probe_regression"],
    "maxSafeBatchPerNight": 12,
    "recommendedBatches": 10,
    "destructivePatchForbidden": true,
    "forbiddenPathEscapeStop": true
  },
  "scoreModel": {
    "dimensions": [
      "conversation_surface_score",
      "route_integrity_score",
      "responseplan_score",
      "continuity_memory_score",
      "canon_thought_score",
      "longform_score",
      "learning_growth_score",
      "automation_control_score",
      "supreme_integration_score",
      "overall_worldclass_score"
    ],
    "bands": {
      "seal_candidate": 95,
      "worldclass_candidate": 90,
      "strong_ascent": 85,
      "viable": 70,
      "incomplete_max": 69
    }
  },
  "stopConditions": {
    "passStop": [
      "overall_worldclass_score >= 95",
      "seal_allowed = true",
      "manifest_missing_total = 0",
      "workspace_dirty = false",
      "replay PASS",
      "execution_gate PASS",
      "required probes PASS",
      "longform acceptance PASS",
      "continuity acceptance PASS",
      "growth acceptance PASS"
    ],
    "partialStop": [
      "overall >= 85 with seal blockers",
      "emit next minimal card and stop"
    ],
    "failStop": [
      "build fail",
      "replay regress",
      "probe regress",
      "manifest regress",
      "dirty regression",
      "3 iterations no score improvement"
    ]
  },
  "finalOutputsExpected": [
