{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tenmon-ark.local/automation/human_gate_schema_v1.json",
  "title": "TENMON-ARK Human Gate Record V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requestId",
    "cardName",
    "status",
    "createdAt",
    "updatedAt",
    "decidedBy",
    "note",
    "metadata"
  ],
  "properties": {
    "requestId": {
      "type": "string",
      "minLength": 8,
      "description": "Unique id (e.g. UUID hex)"
    },
    "cardName": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]+_V[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected", "held"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "decidedBy": { "type": ["string", "null"] },
    "note": { "type": "string" },
    "metadata": { "type": "object" }
  }
}
