# TENMON-MC Mission Control locations
# This file is included inside the tenmon-ark.com server block
# Destination: /etc/nginx/snippets/tenmon-mc-locations.conf
#
# 配線:
#   /mc/                 -> 新 AI-HUB overview landing
#   /mc/{quality,alerts,acceptance,sources,repair,history} -> 302 -> /mc/vnext/<name>
#   /mc/vnext/*          -> owner-only SPA（深リンク対応、全 path で SPA index.html を返す）
#   /mc/classic/*        -> 旧 MC-P5 静的ページ (/var/www/tenmon-mc/)
#   /pwa/mc/vnext/*      -> 旧 URL 互換リダイレクト
#
# 実装メモ:
#   - alias が URI 末尾を append する古典的挙動 (HEAD /mc/ で index.htmlindex.html、
#     try_files fallback で index.htmlacceptance になる) を避けるため、
#     単一ファイル配信は専用 `= /__mc_*_serve` location に internal rewrite で委譲する。
#   - rewrite ... last で新 location に飛ぶと auth_basic が落ちるため、
#     internal location 側にも auth_basic を必ず付ける（external からは `internal;` で遮断済）。

# ---------- /mc root: new AI-HUB ----------
location = /mc {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    return 302 /mc/;
}

location = /mc/ {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    default_type text/html;
    rewrite ^ /__mc_hub_serve last;
}

location = /__mc_hub_serve {
    internal;
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    default_type text/html;
    alias /var/www/mc-landing/index.html;
}

# ---------- short redirects ----------
location = /mc/vnext {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/vnext/;
}
location = /mc/quality {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/vnext/quality;
}
location = /mc/alerts {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/vnext/alerts;
}
location = /mc/acceptance {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/vnext/acceptance;
}
location = /mc/sources {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/vnext/sources;
}
location = /mc/repair {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/vnext/repair;
}
location = /mc/history {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/vnext/history;
}

# ---------- /mc/vnext/* : owner-only SPA（全 path で SPA index.html） ----------
location ^~ /mc/vnext/ {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    default_type text/html;
    rewrite ^ /__mc_vnext_serve last;
}

location = /__mc_vnext_serve {
    internal;
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    default_type text/html;
    alias /var/www/tenmon-pwa/pwa/index.html;
}

# ---------- 旧 URL 互換 ----------
location = /pwa/mc/vnext {
    return 302 /mc/vnext/;
}
location ^~ /pwa/mc/vnext/ {
    rewrite ^/pwa/mc/vnext/?(.*)$ /mc/vnext/$1 redirect;
}

# ---------- /mc/classic/* : 旧 MC-P5 静的退避 ----------
location = /mc/classic {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    return 302 /mc/classic/;
}

location ^~ /mc/classic/ {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    default_type text/html;
    alias /var/www/tenmon-mc/;
    try_files $uri $uri/ /__mc_classic_serve;
}

location = /__mc_classic_serve {
    internal;
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;
    default_type text/html;
    alias /var/www/tenmon-mc/index.html;
}

# ---------- back-compat: 旧 MC-P5 の /mc/data/... ポーリングを /mc/classic/data/ に誘導 ----------
location ^~ /mc/data/ {
    rewrite ^/mc/data/(.*)$ /mc/classic/data/$1 permanent;
}
location ^~ /mc/style.css {
    rewrite ^/mc/style\.css$ /mc/classic/style.css permanent;
}
location ^~ /mc/dashboard.html {
    rewrite ^/mc/dashboard\.html$ /mc/classic/dashboard.html permanent;
}
location ^~ /mc/ai_agents.html {
    rewrite ^/mc/ai_agents\.html$ /mc/classic/ai_agents.html permanent;
}

# ---------- /api/mc/vnext/claude-summary : CARD-MC-16 AI read lane（Bearer のみ、Basic なし） ----------
location = /api/mc/vnext/claude-summary {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Authorization     $http_authorization;
    proxy_set_header X-Tenmon-MC-Basic-Trust "";
}

# ---------- /api/mc/vnext/* : Basic-auth-trusted proxy for the MC SPA ----------
# 画面 (/mc/*) と同じ Basic auth で owner-only に守る。
# 通過したリクエストにだけ信頼ヘッダを付けて API に渡し、
# API 側では X-Tenmon-MC-Basic-Trust + loopback 経由なら founder auth を bypass する。
# 生の /api/ proxy ではこのヘッダは削除済み（defense-in-depth）。
location ^~ /api/mc/vnext/ {
    auth_basic "TENMON-MC (Owner Only)";
    auth_basic_user_file /var/www/tenmon-mc/.htpasswd;
    include /etc/nginx/snippets/tenmon-mc-trust.conf;
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Authorization     "";
    proxy_set_header X-Tenmon-MC-Basic-Trust $tenmon_mc_trust_token;
}
